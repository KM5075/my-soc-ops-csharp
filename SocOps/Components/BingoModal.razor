<div class="fixed inset-0 modal-backdrop flex items-center justify-center p-4 z-50">
    <div class="modal-panel rounded-xl p-6 max-w-xs w-full text-center animate-[bounce_0.5s_ease-out]">
        <div class="text-5xl mb-4">LOCK</div>
        <h2 class="text-3xl font-bold mb-2">BINGO CONFIRMED</h2>
        <p class="mb-6">A complete line has been validated.</p>

        <button
            @onclick="OnDismiss"
            class="launch-button w-full py-3 px-6 rounded-lg transition-colors">
            Continue Mission
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
