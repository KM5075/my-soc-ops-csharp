@using SocOps.Models

<div class="theme-shell game-shell flex flex-col min-h-full">
    <div class="theme-grid-overlay" aria-hidden="true"></div>

    <header class="game-header panel-card flex items-center justify-between p-3">
        <button
            @onclick="OnReset"
            class="ghost-button text-sm px-3 py-1.5 rounded">
            Back
        </button>
        <h1 class="font-bold">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <p class="transmission-banner text-center text-sm py-2 px-4">
        Confirm each match by marking the related square.
    </p>

    @if (HasBingo)
    {
        <div class="bingo-alert text-center py-2 font-semibold text-sm">
            BINGO LOCKED: A full line has been secured.
        </div>
    }

    <div class="flex-1 flex items-center justify-center p-3 board-stage">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
