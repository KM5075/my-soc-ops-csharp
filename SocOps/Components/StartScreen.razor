<div class="theme-shell flex flex-col items-center justify-center min-h-full p-6">
    <div class="theme-grid-overlay" aria-hidden="true"></div>

    <div class="text-center max-w-sm start-stage w-full">
        <p class="control-kicker mb-3">MISSION CONTROL</p>
        <h1 class="mission-title mb-2">Soc Ops</h1>
        <p class="signal-subtitle mb-8">Social Bingo</p>

        <div class="panel-card p-6 mb-8">
            <h2 class="font-semibold mb-3">Operational Brief</h2>
            <ul class="text-left text-sm space-y-2 rules-list">
                <li>Find people who match each prompt.</li>
                <li>Tap a square to mark a confirmed contact.</li>
                <li>Secure five in a row to complete the mission.</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="launch-button w-full py-4 px-8 text-lg">
            Initiate Round
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
